meta {
  name: Cadastrar Usuários
  type: http
  seq: 1
}

post {
  url: http://localhost/atendelab/public/?controller=usuarios&action=criar
  body: formUrlEncoded
  auth: inherit
}

params:query {
  controller: usuarios
  action: criar
}

body:form-urlencoded {
  nome: João Teste
  email: joao.teste@atendelab.com
  senha: 123456
  perfil: atendente
  status: ativo
}

settings {
  encodeUrl: true
  timeout: 0
}
